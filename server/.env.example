# Copy this to .env and fill in your values before deploying to Railway

# PostgreSQL — Railway auto-sets this when you link a Postgres service
DATABASE_URL=postgresql://user:password@host:5432/nuketycoon

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_random_64_char_hex_string

# Resend email API key — free account at https://resend.com (100 emails/day free)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address.
# Resend onboarding (before verifying a domain): onboarding@resend.dev
#   → can only send to the email address on your Resend account, good for initial testing.
# After you verify your own domain, change this to: Nuclear Tycoon <noreply@yourdomain.com>
EMAIL_FROM=onboarding@resend.dev

# Where your front-end is hosted (used for CORS)
# During dev: http://localhost:5500  or  http://127.0.0.1:5500
CLIENT_ORIGIN=https://your-nuketycoon-frontend.railway.app

# Port — Railway sets this automatically, leave as 3001 for local dev
PORT=3001

# How long each run-day lasts in milliseconds.
# 86400000 = 24 real hours (production)
# 60000    = 1 minute  (fast testing)
DAY_DURATION_MS=86400000
RUN_LENGTH=3
